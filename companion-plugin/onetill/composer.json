{
	"name": "onetill/woocommerce-connector",
	"description": "WooCommerce companion plugin for OneTill POS",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4",
		"chillerlan/php-qrcode": "^5.0"
	},
	"autoload": {
		"psr-4": {
			"OneTill\\": "includes/"
