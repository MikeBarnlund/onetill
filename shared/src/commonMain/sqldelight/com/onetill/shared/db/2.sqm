-- Migration: Add product tags support
CREATE TABLE IF NOT EXISTS product_tag (
    id INTEGER NOT NULL PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS product_tag_join (
    product_id INTEGER NOT NULL,
    tag_id INTEGER NOT NULL,
    PRIMARY KEY (product_id, tag_id),
    FOREIGN KEY (product_id) REFERENCES product_cache(id) ON DELETE CASCADE,
    FOREIGN KEY (tag_id) REFERENCES product_tag(id) ON DELETE CASCADE
);
